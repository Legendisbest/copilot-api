# Core runtime
HOST_PORT=8080
GH_TOKEN=
API_KEY=change-this-api-key
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=replace-with-a-long-random-secret

# Browser exposure
CORS_ALLOWED_ORIGINS=http://localhost:8080
CORS_ALLOW_CREDENTIALS=false

# Postgres backing store for multi-account deployments
POSTGRES_DB=copilot
POSTGRES_USER=copilot
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgres://copilot:change-this-db-password@postgres:5432/copilot

# Conservative traffic shaping defaults
TRAFFIC_CONTROL_ENABLED=true
GLOBAL_MIN_DELAY_MS=8000
GLOBAL_DELAY_JITTER_MS=2500
GLOBAL_MAX_CONCURRENT_REQUESTS=1
GLOBAL_QUEUE_ENABLED=true
GLOBAL_MAX_QUEUE_SIZE=100
GLOBAL_MAX_QUEUE_WAIT_MS=900000
GLOBAL_MAX_REQUESTS_PER_MINUTE=6
GLOBAL_MAX_REQUESTS_PER_HOUR=60
GLOBAL_MAX_REQUESTS_PER_DAY=300

# Account rotation safety defaults
LIMIT_ENFORCEMENT_ENABLED=true
DEFAULT_MAX_REQUESTS_PER_HOUR=40
DEFAULT_MAX_REQUESTS_PER_DAY=200
DEFAULT_RATE_LIMIT_COOLDOWN_SECONDS=180
FREE_ACCOUNT_POLICY=prefer_free
FREE_ACCOUNT_EXHAUSTED_ERROR=true
AUTO_DISABLE_FREE_EXHAUSTED=true
AUTO_DISABLE_ON_LIMIT_REACHED=true
